<?xml version="1.0"?>
<sdf version='1.9'>
  <model name='rover_with_aruco'>
    <!-- =========================== CHASSIS (底盤) =========================== -->
    <link name='base_link'>
      <pose>0 0 0.3 0 0 0</pose>

      <!-- Inertial properties (慣性) -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>80.0</mass>
        <inertia>
          <ixx>26.666667</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>26.666667</iyy>
          <iyz>0</iyz>
          <izz>53.333333</izz>
        </inertia>
      </inertial>

      <!-- collision (碰撞) -->
      <collision name='base_coll'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>2 2 0.2</size>
          </box>
        </geometry>
      </collision>
      
      <!-- Visual and collision (外觀與顏色) -->
      <!-- <material>：紅色 綠色 藍色 透明度（alpha）-->
      <!-- <ambient>：物體在陰影中呈現的顏色（環境光）-->
      <!-- <diffuse>：物體被光照射時的顏色（主色）-->
      <!-- <specular>：物體表面反光的顏色（高光） -->
      <visual name='base_vis'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>2 2 0.2</size>
          </box>
        </geometry>
        <material>
          <diffuse>0.7 0.7 0.7 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>

      <!-- IMU 感測器 -->
      <sensor name="imu_sensor" type="imu">
        <pose degrees="true">0 0 0 180 0 0</pose>
        <always_on>1</always_on>
        <update_rate>1000</update_rate>
      </sensor>

      <!-- Air 氣壓計 -->
      <sensor name="air_pressure_sensor" type="air_pressure">
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <air_pressure>
          <pressure>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>0.01</stddev>
            </noise>
          </pressure>
        </air_pressure>
      </sensor>
    </link>

    <!-- =========================== 左前輪 =========================== -->
    <link name='lf_wheel_link'>
      <pose>0.90 1.075 0.30 0 0 0</pose>

      <!-- Inertial properties (慣性) -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.0381</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0381</iyy>
          <iyz>0</iyz>
          <izz>0.0612</izz>
        </inertia>
      </inertial>

      <!-- collision (碰撞) -->
      <collision name='lf_coll'>
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        
        <!-- 表面係數 -->
        <surface>
          <friction>
            <ode>
              <mu>0.70</mu>
              <mu2>0.625</mu2>
              <fdir1>1 0 0</fdir1>
            </ode>
            <torsional>
              <coefficient>0.15</coefficient>
              <use_patch_radius>1</use_patch_radius>
              <surface_radius>0.15</surface_radius>
            </torsional>
          </friction>
          <bounce>
            <restitution_coefficient>0</restitution_coefficient>
            <threshold>1e6</threshold>
          </bounce>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0.0</max_vel>
              <kp>1.0e6</kp>
              <kd>100.0</kd>
            </ode>
          </contact>
        </surface>
      </collision>

      <!-- Visual and collision (外觀與顏色) -->
      <visual name='lf_vis'>
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <!-- Joint Controllers (控制) -->
    <joint name='motor_lf' type='revolute'>
      <parent>base_link</parent>
      <child>lf_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.0005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- =========================== 左後輪 =========================== -->
    <link name='lb_wheel_link'>
      <pose>-0.90 1.075 0.30 0 0 0</pose>

      <!-- Inertial properties (慣性) -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.0381</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0381</iyy>
          <iyz>0</iyz>
          <izz>0.0612</izz>
        </inertia>
      </inertial>

      <!-- collision (碰撞) -->
      <collision name='lb_coll'>
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>

        <!-- 表面係數 -->
        <surface>
          <friction>
            <ode>
              <mu>0.70</mu>
              <mu2>0.625</mu2>
              <fdir1>1 0 0</fdir1>
            </ode>
            <torsional>
              <coefficient>0.15</coefficient>
              <use_patch_radius>1</use_patch_radius>
              <surface_radius>0.15</surface_radius>
            </torsional>
          </friction>
          <bounce>
            <restitution_coefficient>0</restitution_coefficient>
            <threshold>1e6</threshold>
          </bounce>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0.0</max_vel>
              <kp>1.0e6</kp>
              <kd>100.0</kd>
            </ode>
          </contact>
        </surface>
      </collision>

      <!-- Visual and collision (外觀與顏色) -->
      <visual name='lb_vis'>
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <!-- Joint Controllers (控制) -->
    <joint name='motor_lb' type='revolute'>
      <parent>base_link</parent>
      <child>lb_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.0005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- =========================== 右前輪 =========================== -->
    <link name='rf_wheel_link'>
      <pose>0.90 -1.075 0.30 0 0 0</pose>

      <!-- Inertial properties (慣性) -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.0381</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0381</iyy>
          <iyz>0</iyz>
          <izz>0.0612</izz>
        </inertia>
      </inertial>

      <!-- collision (碰撞) -->
      <collision name='rf_coll'>
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>

        <!-- 表面係數 -->
        <surface>
          <friction>
            <ode>
              <mu>0.70</mu>
              <mu2>0.625</mu2>
              <fdir1>1 0 0</fdir1>
            </ode>
            <torsional>
              <coefficient>0.15</coefficient>
              <use_patch_radius>1</use_patch_radius>
              <surface_radius>0.15</surface_radius>
            </torsional>
          </friction>
          <bounce>
            <restitution_coefficient>0</restitution_coefficient>
            <threshold>1e6</threshold>
          </bounce>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0.0</max_vel>
              <kp>1.0e6</kp>
              <kd>100.0</kd>
            </ode>
          </contact>
        </surface>
      </collision>

      <!-- Visual and collision (外觀與顏色) -->
      <visual name='rf_vis'>
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <!-- Joint Controllers (控制) -->
    <joint name='motor_rf' type='revolute'>
      <parent>base_link</parent>
      <child>rf_wheel_link</child>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.0005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- =========================== 右後輪 =========================== -->
    <link name='rb_wheel_link'>
      <pose>-0.90 -1.075 0.30 0 0 0</pose>

      <!-- Inertial properties (慣性) -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.0381</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0381</iyy>
          <iyz>0</iyz>
          <izz>0.0612</izz>
        </inertia>
      </inertial>

      <!-- collision (碰撞) -->
      <collision name='rb_coll'>
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>

        <!-- 表面係數 -->
        <surface>
          <friction>
            <ode>
              <mu>0.70</mu>
              <mu2>0.625</mu2>
              <fdir1>1 0 0</fdir1>
            </ode>
            <torsional>
              <coefficient>0.15</coefficient>
              <use_patch_radius>1</use_patch_radius>
              <surface_radius>0.15</surface_radius>
            </torsional>
          </friction>
          <bounce>
            <restitution_coefficient>0</restitution_coefficient>
            <threshold>1e6</threshold>
          </bounce>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0.0</max_vel>
              <kp>1.0e6</kp>
              <kd>100.0</kd>
            </ode>
          </contact>
        </surface>
      </collision>

      <!-- Visual and collision (外觀與顏色) -->
      <visual name='rb_vis'>
        <pose>0 0 0 1.57079632679 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.1 0.1 0.1 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <!-- Joint Controllers (控制) -->
    <joint name='motor_rb' type='revolute'>
      <parent>base_link</parent>
      <child>rb_wheel_link</child>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>0.0005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ======================== ARUCO PANEL ======================== -->
    <link name='aruco_panel_link'>
      <pose degrees="true">0 0 0.455 0 0 -90</pose>

      <!-- Inertial properties (慣性) -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.1875</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.1875</iyy>
          <iyz>0</iyz>
          <izz>0.375</izz>
        </inertia>
      </inertial>

      <!-- collision (碰撞) -->
      <collision name='aruco_coll'>
        <geometry>
          <box>
            <size>1.5 1.5 0.01</size>
          </box>
        </geometry>
      </collision>

      <!-- Visual and collision (外觀與顏色) -->
      <visual name="aruco_visual">
        <pose>0 0 0 0 0 0</pose>
        <cast_shadows>false</cast_shadows>
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>1.5 1.5</size>
          </plane>
        </geometry>
        <material>
          <ambient>0.8 0.8 0.8 1</ambient>
          <diffuse>0.8 0.8 0.8 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
          <pbr>
            <metal>
              <albedo_map>materials/textures/aruco_04.png</albedo_map>
              <roughness>0.6</roughness>
              <metalness>0</metalness>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>

    <!-- Joint Controllers (控制) -->
    <joint name='aruco_panel_fixed' type='fixed'>
      <parent>base_link</parent>
      <child>aruco_panel_link</child>
    </joint>

    <!-- ==================== GZ SYSTEM PLUGINS ====================== -->
    <plugin name="gz::sim::systems::JointStatePublisher"
      filename="gz-sim-joint-state-publisher-system">
    </plugin>

    <plugin name='gz::sim::systems::OdometryPublisher' filename='gz-sim-odometry-publisher-system'>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <dimensions>3</dimensions>
    </plugin>
    
    <plugin filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>motor_lf</joint_name>
      </plugin>
    <plugin filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>motor_lb</joint_name>
      </plugin>
    <plugin filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>motor_rf</joint_name>
    </plugin>
    <plugin
      filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>motor_rb</joint_name>
    </plugin>

    <!-- ===================== ARDUPILOT PLUGIN ====================== -->
    <plugin name='ArduPilotPlugin' filename='ArduPilotPlugin'>
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9022</fdm_port_in>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <lock_step>1</lock_step>
      <!-- Retain user's original transforms; adjust if needed -->
      <gazeboXYZToNED degrees='true'>0 0 0 180 0 90</gazeboXYZToNED>
      <modelXYZToAirplaneXForwardZDown degrees='true'>0 0 0 180 0 0</modelXYZToAirplaneXForwardZDown>
      <imuName>base_link::imu_sensor</imuName>

      <!-- LEFT SIDE (front + rear) -->
      <control channel='0'>
        <jointName>motor_lf</jointName>
        <useForce>1</useForce>
        <type>VELOCITY</type>
        <multiplier>133.33</multiplier>
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <p_gain>1.4</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>0.0001</d_gain>
        <i_max>1</i_max>
        <i_min>-1</i_min>
        <cmd_max>22</cmd_max>
        <cmd_min>-22</cmd_min>
      </control>
      <control channel='0'>
        <jointName>motor_lb</jointName>
        <useForce>1</useForce>
        <type>VELOCITY</type>
        <multiplier>133.33</multiplier>
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <p_gain>1.4</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>0.0001</d_gain>
        <i_max>1</i_max>
        <i_min>-1</i_min>
        <cmd_max>22</cmd_max>
        <cmd_min>-22</cmd_min>
      </control>

      <!-- RIGHT SIDE (front + rear)  NOTE: negative multiplier for mirrored axis -->
      <control channel='2'>
        <jointName>motor_rf</jointName>
        <useForce>1</useForce>
        <type>VELOCITY</type>
        <multiplier>-133.33</multiplier>
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <p_gain>1.4</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>0.0001</d_gain>
        <i_max>1</i_max>
        <i_min>-1</i_min>
        <cmd_max>22</cmd_max>
        <cmd_min>-22</cmd_min>
      </control>
      <control channel='2'>
        <jointName>motor_rb</jointName>
        <useForce>1</useForce>
        <type>VELOCITY</type>
        <multiplier>-133.33</multiplier>
        <offset>-0.5</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <p_gain>1.4</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>0.001</d_gain>
        <i_max>1</i_max>
        <i_min>-1</i_min>
        <cmd_max>22</cmd_max>
        <cmd_min>-22</cmd_min>
      </control>
    </plugin>

  </model>
</sdf>
